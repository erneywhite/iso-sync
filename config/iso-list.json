        "_comment_proxmox": "Family-режим: одна запись = одно семейство (мажорная ветка). URL — узел CDN de.cdn.proxmox.com напрямую + ip_version:v6. Почему так: официальный download.proxmox.com по IPv4 заблокирован из ряда сетей (напр. netcup AS197540 — TCP таймаутит), а по IPv6 серт CDN-узла не содержит имя download.proxmox.com (только enterprise + *.cdn.proxmox.com). Обращение к de.cdn.proxmox.com напрямую по IPv6: серт валиден (de.cdn в SAN), это официальный CDN (свежий, не зеркало), IPv4-блок обойдён. Если у вас всё доступно по IPv4 — верните url_dir на https://download.proxmox.com/iso/ и уберите ip_version (дефолт v4).",
        "proxmox-ve-7": {
            "local_subdir":        "Proxmox",
            "url_dir":             "https://de.cdn.proxmox.com/iso/",
            "ip_version":          "v6",
            "remote_pattern":      "/^proxmox-ve_7\\.(\\d+)-\\d+\\.iso$/",
            "local_name_template": "ProxmoxVE_7.{1}.iso",
            "cleanup_old":         true
        },
        "proxmox-ve-8": {
            "local_subdir":        "Proxmox",
            "url_dir":             "https://de.cdn.proxmox.com/iso/",
            "ip_version":          "v6",
            "remote_pattern":      "/^proxmox-ve_8\\.(\\d+)-\\d+\\.iso$/",
            "local_name_template": "ProxmoxVE_8.{1}.iso",
            "cleanup_old":         true
        },
        "proxmox-ve-9": {
            "local_subdir":        "Proxmox",
            "url_dir":             "https://de.cdn.proxmox.com/iso/",
            "ip_version":          "v6",
            "remote_pattern":      "/^proxmox-ve_9\\.(\\d+)-\\d+\\.iso$/",
            "local_name_template": "ProxmoxVE_9.{1}.iso",
            "cleanup_old":         true
        },
        "proxmox-backup-4": {
            "local_subdir":        "Proxmox",
            "url_dir":             "https://de.cdn.proxmox.com/iso/",
            "ip_version":          "v6",
            "remote_pattern":      "/^proxmox-backup-server_4\\.(\\d+)-\\d+\\.iso$/",
